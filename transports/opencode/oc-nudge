#!/usr/bin/env bash
set -euo pipefail

script_dir=$(CDPATH= cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)

usage() {
  cat <<'END_USAGE'
Usage:
  oc-nudge [-p|--person] [--model NAME] SESSION_ID MESSAGE...
  oc-nudge [-p|--person] -n HOST [--model NAME] MESSAGE...
  oc-nudge [-p|--person] [--model NAME] --to-session ID [--to-server URL] MESSAGE...
  oc-nudge --from-server URL --from-session ID --to-server URL --to-session ID MESSAGE...
  oc-nudge --list HOST
  oc-nudge --help

Sender (standard): omit --from / --from-server / --from-session. oc-nudge uses
oc-snoop to discover this machine's OpenCode server and oc-whoami to discover
the current OpenCode tool session.

The first positional argument starting with "ses_" is the target session ID.
oc-nudge resolves its host via oc-find unless --to-server is also specified.

Options:
  -p, --person    Terminal/person mode. Sender is labeled "Human".
  -n, --new HOST   Create a session on HOST and send the message.
  --help           Show this help.
  --model NAME     Specify the provider/model (e.g., deepseek/deepseek-v4-flash).
  --to-server URL  Target server URL (optional; resolved via oc-find if omitted).
  --to-session ID  Target session ID.
  --list HOST      List sessions on HOST.

Environment:
  OC_NUDGE_FROM           Default sender alias
  OC_NUDGE_FROM_SERVER    Default sender OpenCode server URL
  OC_NUDGE_FROM_SESSION   Default sender OpenCode session ID
  OC_NUDGE_TIMEOUT        Curl timeout in seconds (default: 15)

Examples:
  oc-nudge ses_177...QI "please check status"
  oc-nudge -n thinkpad "wake up"
  oc-nudge --to-session ses_abc "msg"
  oc-nudge --to-server http://thinkpad.local:4096 --to-session ses_abc "explicit"
  oc-nudge --list thinkpad

Multi-line example:

oc-nudge ses_177...QI <<\
‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ

multiline message

‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
END_USAGE
}

die() {
  printf 'oc-nudge: %s\n' "$*" >&2
  exit 1
}

need_cmd() {
  command -v "$1" >/dev/null 2>&1 || die "missing required command: $1"
}

json_escape() {
  local value=$1
  value=${value//\\/\\\\}
  value=${value//\"/\\\"}
  value=${value//$'\b'/\\b}
  value=${value//$'\f'/\\f}
  value=${value//$'\n'/\\n}
  value=${value//$'\r'/\\r}
  value=${value//$'\t'/\\t}
  printf '%s' "$value"
}

json_string() {
  printf '"%s"' "$(json_escape "$1")"
}

read_stdin_message() {
  local value
  value=$(cat)
  while [[ $value == $'\n'* ]]; do
    value=${value#$'\n'}
  done
  printf '%s' "$value"
}

resolve_host() {
  local session_id=$1
  local host
  host=$("$script_dir/oc-find" "$session_id" 2>/dev/null) || true
  [[ -n $host ]] || die "could not resolve session $session_id to host (try --to-server for manual routing)"
  printf '%s' "$host"
}

derive_url() {
  local host=$1
  printf 'http://%s.local:4096' "$host"
}

normalize_url() {
  local url=$1
  if [[ "$url" != *:*:* ]]; then
    url="${url%/}:4096"
  fi
  printf '%s\n' "$url"
}

send_nudge() {
  local from_server=$1 from_session=$2 to_server=$3 to_session=$4 message=$5
  local model=${6:-}

  local nudge
  local from_host=${from_server#*://}
  from_host=${from_host%%:*}
  from_host=${from_host%/}
  local model_suffix="" reply_instruction="Nudge if replying."
  [[ -n "${model:-}" ]] && model_suffix=" ¬∑ ${model}"
  if [[ "$from_session" == "Human" ]]; then
    reply_instruction="Use chat if replying."
  fi
  nudge=$(cat <<EOF
$from_session nudging from $from_host$model_suffix:
‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ

$message

‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
$reply_instruction
EOF
  )

  local http_code to_display
  to_display=${to_server#http://}
  to_display=${to_display#https://}
  local payload
  if [[ -n "$model" ]]; then
    local provider=${model%/*} model_id=${model#*/}
    if [[ "$provider" == "$model" ]]; then
      payload=$(printf '{"model":{"providerID":"%s"},"parts":[{"type":"text","text":%s}]}' "$provider" "$(json_string "$nudge")")
    else
      payload=$(printf '{"model":{"providerID":"%s","modelID":"%s"},"parts":[{"type":"text","text":%s}]}' "$provider" "$model_id" "$(json_string "$nudge")")
    fi
  else
    payload=$(printf '{"parts":[{"type":"text","text":%s}]}' "$(json_string "$nudge")")
  fi
  tmp=${TMPDIR:-/tmp}/oc-nudge-response.$$
  trap 'rm -f "$tmp"' RETURN

  http_code=$(
    curl -sS -o "$tmp" -w '%{http_code}' --max-time "${OC_NUDGE_TIMEOUT:-15}" \
      -X POST "$to_server/session/$to_session/prompt_async" \
      -H 'Content-Type: application/json' \
      -d "$payload"
  )

  case "$http_code" in
    204)
      printf 'Nudged %s/session/%s\n' "$to_display" "$to_session" >&2
      return 0
      ;;
    *)
      printf 'oc-nudge: POST failed to %s/session/%s with HTTP %s\n' "$to_server" "$to_session" "$http_code" >&2
      if [[ -s "$tmp" ]]; then
        printf '%s\n' '--- response body ---' >&2
        sed 's/^/  /' "$tmp" >&2
      fi
      return 1
      ;;
  esac
}

create_session() {
  local server=$1 title=${2:-nudge}

  local resp session
  resp=$(curl -sS --max-time "${OC_NUDGE_TIMEOUT:-15}" \
    -X POST "$server/session" \
    -H 'Content-Type: application/json' \
    -d "{\"title\":\"$title\"}" 2>/dev/null) || die "failed to create session on $server"

  session=$(printf '%s\n' "$resp" | grep -o '"id":"ses_[^"]*"' | head -1 | sed 's/"id":"//;s/"//')

  [[ -n ${session:-} ]] || die "could not parse session ID from response: $resp"

  printf '%s\n' "$session"
}

list_sessions() {
  local host=$1
  local url
  url=$(derive_url "$host")
  curl -s --max-time "${OC_NUDGE_TIMEOUT:-15}" "$url/session" 2>/dev/null || die "could not reach $url"
}

need_cmd curl

from_server=${OC_NUDGE_FROM_SERVER:-}
from_session=${OC_NUDGE_FROM_SESSION:-}
to_server=
to_session=
new_host=
model=
human_mode=0
list_host=

while [[ $# -gt 0 ]]; do
  case "$1" in
    -h|--help)
      usage
      exit 0
      ;;
    -p|--person)
      human_mode=1
      from_session=${from_session:-Human}
      shift
      ;;
    --from-server)
      [[ $# -ge 2 ]] || die "--from-server requires a URL"
      from_server=$2
      shift 2
      ;;
    --from-session)
      [[ $# -ge 2 ]] || die "--from-session requires a session ID"
      from_session=$2
      shift 2
      ;;
    --to-server)
      [[ $# -ge 2 ]] || die "--to-server requires a URL"
      to_server=$2
      shift 2
      ;;
    --to-session)
      [[ $# -ge 2 ]] || die "--to-session requires a session ID"
      to_session=$2
      shift 2
      ;;
    -n|--new)
      [[ $# -ge 2 ]] || die "-n requires a hostname"
      new_host=$2
      shift 2
      ;;
    --model)
      [[ $# -ge 2 ]] || die "--model requires a provider/model name"
      model=$2
      shift 2
      ;;
    --list)
      [[ $# -ge 2 ]] || die "--list requires a hostname"
      list_host=$2
      shift 2
      ;;
    --list-targets)
      die "--list-targets has been removed; use --list <host> to list sessions on a host"
      ;;
    --targets)
      die "--targets has been removed; use --list <host> or rely on oc-find for host resolution"
      ;;
    --)
      shift
      break
      ;;
    -)
      break
      ;;
    -*)
      die "unknown option: $1"
      ;;
    *)
      break
      ;;
  esac
done

# ‚îÄ‚îÄ --list mode ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ

if [[ -n $list_host ]]; then
  list_sessions "$list_host"
  exit 0
fi

# ‚îÄ‚îÄ discover sender ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ

if [[ -z "$from_server" ]] && command -v oc-snoop >/dev/null 2>&1; then
  from_server=$(oc-snoop --server)
fi

if [[ -z "$from_session" && $human_mode -eq 0 ]]; then
  command -v oc-whoami >/dev/null 2>&1 || die "sender session missing: set --from-session or use -p/--person from a terminal"
  from_session=$(oc-whoami --match oc-nudge) || die "sender session missing: set --from-session or use -p/--person from a terminal"
fi

[[ -n "$from_server" ]] || die "sender route missing: set --from-server or install oc-snoop"
[[ -n "$from_session" ]] || die "sender session missing: set --from-session or use -p/--person from a terminal"
from_server=$(normalize_url "$from_server")
from_server=${from_server%/}

# ‚îÄ‚îÄ resolve target ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ

if [[ -n $new_host ]]; then
  # -n HOST: create new session
  to_server=${to_server:-$(derive_url "$new_host")}
  to_server=$(normalize_url "$to_server")
  to_server=${to_server%/}
  to_session=$(create_session "$to_server" "Nudge from $from_session")
elif [[ -z $to_session ]]; then
  # No --to-session or -n given: look for a session ID in positionals
  for arg in "$@"; do
    if [[ "$arg" == ses_* ]]; then
      to_session=$arg
      break
    fi
  done
  [[ -n ${to_session:-} ]] || die "no session ID found in arguments (use ses_... or --to-session)"
fi

# If to_server not explicitly set, resolve via to_session (now guaranteed non-empty)
if [[ -z $to_server ]]; then
  host=$(resolve_host "$to_session")
  to_server=$(derive_url "$host")
fi
to_server=$(normalize_url "$to_server")
to_server=${to_server%/}

# ‚îÄ‚îÄ message ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ

# Eat the session ID from positionals if we parsed it from there
if [[ -n ${to_session:-} ]] && [[ "${1:-}" == "$to_session" ]]; then
  shift
fi

if [[ "${1:-}" == "-" && $# -eq 1 ]]; then
  message=$(read_stdin_message)
elif [[ $# -eq 0 ]]; then
  [[ ! -t 0 ]] || die "expected MESSAGE... or stdin"
  message=$(read_stdin_message)
else
  message=$*
fi

# ‚îÄ‚îÄ send ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ

send_nudge "$from_server" "$from_session" "$to_server" "$to_session" "$message" "$model"
