#!/usr/bin/env bash
# oc-revive: restart the local OpenCode server gracefully
#
# Launch THIS before killing your OC process.
# It waits for the port to free, then starts a new instance.
#
# Usage:
#   oc-revive            # auto-discovers port via oc-snoop
#   oc-revive 4096       # explicit port
#   oc-revive --kill     # kill a running reviver

set -euo pipefail

NAME="oc-revive"
LOCK="/tmp/${NAME}.pid"
die() { printf '%s: %s\n' "$NAME" "$*" >&2; exit 1; }

if [[ "${1:-}" == "--kill" ]]; then
  if [[ -f "$LOCK" ]]; then
    read -r pid < "$LOCK"
    kill "$pid" 2>/dev/null && rm -f "$LOCK" && die "killed reviver $pid"
    rm -f "$LOCK"
  fi
  pid=$(pgrep -f "[o]c-revive.*wait" 2>/dev/null | head -1) || true
  [[ -n "$pid" ]] && kill "$pid" 2>/dev/null && die "killed orphan reviver $pid"
  die "no reviver found"
fi

port=${1:-}
if [[ -z "$port" ]]; then
  port=$(oc-snoop --server 2>/dev/null | grep -oE '[0-9]+$') || true
fi
port=${port:-4096}

nohup bash -c "
  while ss -ltn 2>/dev/null | grep -q ':$port '; do
    sleep 1
  done
  opencode serve --hostname 0.0.0.0 --port $port
" &>/dev/null &

pid=$!
disown $pid 2>/dev/null || true
printf '%s\n' "$pid" > "$LOCK"
printf '%s: armed on port %s (pid %s). Safe to kill OC.\n' "$NAME" "$port" "$pid"
