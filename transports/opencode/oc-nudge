#!/usr/bin/env bash
set -euo pipefail

script_dir=$(CDPATH= cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)
targets_file=${OC_NUDGE_TARGETS:-$script_dir/targets.local.tsv}

usage() {
  cat <<'END_USAGE'
Usage:
  oc-nudge [-p|--person] [-n] [--model PROVIDER] TARGET_ALIAS [TARGET_ALIAS...] MESSAGE...
  oc-nudge [-p|--person] [-n] [--model PROVIDER] TARGET_ALIAS SESSION_ID MESSAGE...
  oc-nudge [--from FROM_ALIAS] [-n] [--model PROVIDER] TARGET_ALIAS [TARGET_ALIAS...] MESSAGE...
  oc-nudge --from-server URL --from-session ID [-n] [--model PROVIDER] TARGET_ALIAS [TARGET_ALIAS...] MESSAGE...
  oc-nudge --from-server URL --from-session ID --to-server URL --to-session ID MESSAGE...
  oc-nudge --list-targets

Sender (standard): omit --from / --from-server / --from-session. oc-nudge uses
oc-snoop to discover this machine's OpenCode server and oc-whoami to discover
the current OpenCode tool session.

Recipients: prefer TARGET_ALIAS. Use TARGET_ALIAS SESSION_ID when sending to a
known session on a known target host. Use --to-server/--to-session only for
direct routes that are not in the target table.

Options:
  -p, --person  Terminal/person mode. Sender is labeled "Human" instead of a
                 session ID.
  -n, --new      Create a new session on the target server instead of using the
                 existing one. Reports the new session ID back to stdout.
  --help         Show this help.
  --model NAME   Specify the provider to use on the target side (e.g., deepseek).
                 Adds a Model: header to the nudge body and passes providerID
                 in the API request so the recipient agent uses the right model.

Environment:
  OC_NUDGE_TARGETS       Target table path (default: targets.local.tsv next to this script)
  OC_NUDGE_FROM          Default sender alias
  OC_NUDGE_FROM_SERVER   Default sender OpenCode server URL
  OC_NUDGE_FROM_SESSION  Default sender OpenCode session ID
  OC_NUDGE_TIMEOUT       Curl timeout in seconds (default: 15)

Target table format:
  alias  server-url  session-id

Examples:
  oc-nudge thinkpad "please check status"
  oc-nudge samsung ses_abc "message to a specific session on samsung"
  oc-nudge -p samsung ses_abc "message from terminal"
  oc-nudge --model openai/gpt-5.5 thinkpad "review this patch"
  oc-nudge -n thinkpad "wake up"

Multi-line example:

oc-nudge -n thinkpad <<\
────────────────

multiline message

────────────────

Direct route example, for targets not in the target table:

  oc-nudge --to-server http://127.0.0.1:4096 --to-session ses_abc "no alias route"
  oc-nudge --from samsung thinkpad "when snoop unavailable or wrong session"
  oc-nudge --from-server http://samsung.local --from-session ses_abc thinkpad "explicit route"
END_USAGE
}

die() {
  printf 'oc-nudge: %s\n' "$*" >&2
  exit 1
}

need_cmd() {
  command -v "$1" >/dev/null 2>&1 || die "missing required command: $1"
}

json_escape() {
  local value=$1
  value=${value//\\/\\\\}
  value=${value//"/\\"}
  value=${value//$'\b'/\\b}
  value=${value//$'\f'/\\f}
  value=${value//$'\n'/\\n}
  value=${value//$'\r'/\\r}
  value=${value//$'\t'/\\t}
  printf '%s' "$value"
}

json_string() {
  printf '"%s"' "$(json_escape "$1")"
}

read_stdin_message() {
  local value
  value=$(cat)
  # The nudge envelope owns vertical spacing around stdin/heredoc messages.
  # Command substitution already trims trailing newlines; trim leading empty
  # lines as well so visually wrapped input does not add extra top padding.
  while [[ $value == $'\n'* ]]; do
    value=${value#$'\n'}
  done
  printf '%s' "$value"
}

lookup_route() {
  local alias=$1 name server session rest

  [[ -f "$targets_file" ]] || die "target table not found: $targets_file"

  while read -r name server session rest || [[ -n "${name:-}" ]]; do
    [[ -z "${name:-}" ]] && continue
    [[ "$name" == \#* ]] && continue
    if [[ "$name" == "$alias" ]]; then
      [[ -n "${server:-}" && -n "${session:-}" ]] || die "target '$alias' is missing server or session"
      printf '%s\t%s\n' "$server" "$session"
      return
    fi
  done <"$targets_file"

  die "unknown target alias '$alias' in $targets_file"
}

is_known_alias() {
  local alias=$1 name
  [[ -f "$targets_file" ]] || return 1
  while read -r name _ __ || [[ -n "${name:-}" ]]; do
    [[ -z "${name:-}" || "$name" == \#* ]] && continue
    [[ "$name" == "$alias" ]] && return 0
  done <"$targets_file"
  return 1
}

list_targets() {
  local name server session rest

  [[ -f "$targets_file" ]] || die "target table not found: $targets_file"

  while read -r name server session rest || [[ -n "${name:-}" ]]; do
    [[ -z "${name:-}" ]] && continue
    [[ "$name" == \#* ]] && continue
    printf '%-20s %s %s\n' "$name" "$server" "$session"
  done <"$targets_file"
}

normalize_url() {
  local url=$1
  if [[ "$url" != *:*:* ]]; then
    url="${url%/}:4096"
  fi
  printf '%s\n' "$url"
}

send_nudge() {
  local from_server=$1 from_session=$2 to_server=$3 to_session=$4 message=$5
  local model=${6:-}

  local nudge
  local from_host=${from_server#*://}
  from_host=${from_host%%:*}
  from_host=${from_host%/}
  local model_suffix=""
  [[ -n "${model:-}" ]] && model_suffix=" · ${model}"
  nudge=$(cat <<EOF
$from_session nudging from $from_host$model_suffix:
────────────────────────────────

$message

────────────────────────────────
Nudge if replying.
EOF
  )

  local http_code
  payload=$(printf '{"parts":[{"type":"text","text":%s}]' "$(json_string "$nudge")")
  if [[ -n "$model" ]]; then
    local provider=${model%/*} model_id=${model#*/}
    if [[ "$provider" == "$model" ]]; then
      # Only provider given; let server pick default model
      payload=$(printf '{"model":{"providerID":"%s"},"parts":[{"type":"text","text":%s}]}' "$provider" "$(json_string "$nudge")")
    else
      payload=$(printf '{"model":{"providerID":"%s","modelID":"%s"},"parts":[{"type":"text","text":%s}]}' "$provider" "$model_id" "$(json_string "$nudge")")
    fi
  else
    payload=$(printf '{"parts":[{"type":"text","text":%s}]}' "$(json_string "$nudge")")
  fi
  tmp=${TMPDIR:-/tmp}/oc-nudge-response.$$
  trap 'rm -f "$tmp"' RETURN

  http_code=$(
    curl -sS -o "$tmp" -w '%{http_code}' --max-time "${OC_NUDGE_TIMEOUT:-15}" \
      -X POST "$to_server/session/$to_session/prompt_async" \
      -H 'Content-Type: application/json' \
      -d "$payload"
  )

  case "$http_code" in
    2*)
      printf 'Nudge sent to %s/session/%s (HTTP %s).\n' "$to_server" "$to_session" "$http_code" >&2
      return 0
      ;;
    *)
      printf 'oc-nudge: POST failed to %s/session/%s with HTTP %s\n' "$to_server" "$to_session" "$http_code" >&2
      if [[ -s "$tmp" ]]; then
        printf '%s\n' '--- response body ---' >&2
        sed 's/^/  /' "$tmp" >&2
      fi
      return 1
      ;;
  esac
}

create_session() {
  local server=$1 title=${2:-nudge}

  local resp session
  resp=$(curl -sS --max-time "${OC_NUDGE_TIMEOUT:-15}" \
    -X POST "$server/session" \
    -H 'Content-Type: application/json' \
    -d "{\"title\":\"$title\"}" 2>/dev/null) || die "failed to create session on $server"

  session=$(printf '%s\n' "$resp" | grep -o '"id":"ses_[^"]*"' | head -1 | sed 's/"id":"//;s/"//')

  [[ -n ${session:-} ]] || die "could not parse session ID from response: $resp"

  printf '%s\n' "$session"
}

need_cmd curl

from_alias=${OC_NUDGE_FROM:-}
from_server=${OC_NUDGE_FROM_SERVER:-}
from_session=${OC_NUDGE_FROM_SESSION:-}
to_server=
to_session=
new_session=0
model=
human_mode=0

while [[ $# -gt 0 ]]; do
  case "$1" in
    -h|--help)
      usage
      exit 0
      ;;
    -p|--person)
      human_mode=1
      from_session=${from_session:-Human}
      shift
      ;;
    --targets)
      [[ $# -ge 2 ]] || die "--targets requires a file"
      targets_file=$2
      shift 2
      ;;
    --from)
      [[ $# -ge 2 ]] || die "--from requires an alias"
      from_alias=$2
      shift 2
      ;;
    --from-server)
      [[ $# -ge 2 ]] || die "--from-server requires a URL"
      from_server=$2
      shift 2
      ;;
    --from-session)
      [[ $# -ge 2 ]] || die "--from-session requires a session ID"
      from_session=$2
      shift 2
      ;;
    --to-server)
      [[ $# -ge 2 ]] || die "--to-server requires a URL"
      to_server=$2
      shift 2
      ;;
    --to-session)
      [[ $# -ge 2 ]] || die "--to-session requires a session ID"
      to_session=$2
      shift 2
      ;;
    -n|--new)
      new_session=1
      shift
      ;;
    --model)
      [[ $# -ge 2 ]] || die "--model requires a provider name"
      model=$2
      shift 2
      ;;
    --list-targets)
      list_targets
      exit 0
      ;;
    --)
      shift
      break
      ;;
    -)
      break
      ;;
    -*)
      die "unknown option: $1"
      ;;
    *)
      break
      ;;
  esac
done

# Resolve from route
if [[ -n "$from_alias" ]]; then
  read -r alias_server alias_session < <(lookup_route "$from_alias")
  from_server=${from_server:-$alias_server}
  from_session=${from_session:-$alias_session}
fi

# Auto-discover sender pieces if needed. Session discovery is authoritative:
# oc-whoami succeeds for OpenCode tool calls and fails for ordinary terminals.
if [[ -z "$from_server" ]] && command -v oc-snoop >/dev/null 2>&1; then
  from_server=$(oc-snoop --server)
fi

if [[ -z "$from_session" && $human_mode -eq 0 ]]; then
  command -v oc-whoami >/dev/null 2>&1 || die "sender session missing: set --from-session or use -p/--person from a terminal"
  from_session=$(oc-whoami --match oc-nudge) || die "sender session missing: set --from-session or use -p/--person from a terminal"
fi

[[ -n "$from_server" ]] || die "sender route missing: set --from, --from-server, or install oc-snoop"
[[ -n "$from_session" ]] || die "sender session missing: set --from-session or use -p/--person from a terminal"
from_server=$(normalize_url "$from_server")
from_server=${from_server%/}

# Parse recipients and message
targets=()

if [[ -n "$to_server" && -n "$to_session" ]]; then
  # Explicit --to-server / --to-session: single recipient, remainder is message
  to_server=$(normalize_url "$to_server")
  to_server=${to_server%/}
  targets+=("$to_server"$'\t'"$to_session")
else
  # Alias-based: collect all known aliases before the message
  [[ $# -ge 1 ]] || die "expected TARGET_ALIAS [TARGET_ALIAS...] MESSAGE..."

  while [[ $# -gt 1 ]]; do
    if is_known_alias "$1"; then
      s= r=
      read -r s r < <(lookup_route "$1")
      targets+=("$(normalize_url "$s")"$'\t'"$r")
      shift
      if [[ ${1:-} == ses_* ]]; then
        targets[-1]="$(normalize_url "$s")"$'\t'"$1"
        shift
      fi
    else
      break
    fi
  done

  if [[ $# -eq 1 && ! -t 0 ]] && is_known_alias "$1"; then
    s= r=
    read -r s r < <(lookup_route "$1")
    targets+=("$(normalize_url "$s")"$'\t'"$r")
    shift
  fi

  [[ ${#targets[@]} -gt 0 ]] || die "no valid target aliases found"
fi

# Message is everything remaining
if [[ "${1:-}" == "-" && $# -eq 1 ]]; then
  message=$(read_stdin_message)
elif [[ $# -eq 0 ]]; then
  [[ ! -t 0 ]] || die "expected MESSAGE... or stdin"
  message=$(read_stdin_message)
else
  message=$*
fi

# Create new session if --new flag set (only for alias mode, explicit to-session already has one)
if [[ $new_session -eq 1 ]]; then
  new_ids=()
  for i in $(seq 0 $((${#targets[@]} - 1))); do
    server= session=
    server=${targets[$i]%%$'\t'*}
    session=${targets[$i]##*$'\t'}
    if [[ "$session" == ses_* ]]; then
      # Existing session in targets file — still create a new one
      new_id=
      new_id=$(create_session "$server" "Nudge from $from_alias")
      new_ids+=("$new_id")
      targets[$i]="$server"$'\t'"$new_id"
    fi
  done
fi

# Send to each recipient
errors=0
for target in "${targets[@]}"; do
  t_server=${target%%$'\t'*}
  t_session=${target##*$'\t'}
  send_nudge "$from_server" "$from_session" "$t_server" "$t_session" "$message" "$model" || errors=$((errors + 1))
done

exit $(( errors > 0 ? 1 : 0 ))
